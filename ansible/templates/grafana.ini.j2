################################################################################
# Grafana configuration — managed by Ansible
# Deployed to /etc/grafana/grafana.ini on varys (10.0.10.10)
# Secrets sourced from ansible/vault/varys.yml (ansible-vault encrypted)
################################################################################

[server]
# Grafana is accessed directly at http://10.0.10.10:3000 (LAN / Headscale VPN).
# To expose via HTTPS, add a proxy host in NPM on docked pointing to
# http://10.0.10.10:3000 for grafana.kagiso.me, then update root_url below.
protocol = http
http_port = 3000
root_url = http://10.0.10.10:3000

[security]
admin_user = {{ grafana_admin_user }}
admin_password = {{ grafana_admin_password }}
allow_embedding = false
cookie_secure = false
cookie_samesite = lax

[users]
allow_sign_up = false
auto_assign_org = true
auto_assign_org_role = Viewer

[auth.anonymous]
enabled = false

[analytics]
check_for_updates = false
reporting_enabled = false

[log]
mode = console
level = warn

[dashboards]
default_home_dashboard_path =
