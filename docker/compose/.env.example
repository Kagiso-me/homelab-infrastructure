# =============================================================================
# Docker Stack Environment Variables
# Copy this file to .env in the same directory before deploying any stack.
#
# IMPORTANT: .env is gitignored — never commit credentials to the repository.
# =============================================================================

# ---------------------------------------------------------------------------
# Common — used by all stacks
# ---------------------------------------------------------------------------
PUID=1000
PGID=1000
TZ=Africa/Johannesburg

# ---------------------------------------------------------------------------
# Image versions — pin to specific tags for reproducibility
# Check Docker Hub or GHCR for available tags before updating.
# Use "latest" only during initial setup; pin after first deploy:
#   docker inspect --format='{{index .Config.Image}}' plex
# ---------------------------------------------------------------------------
PLEX_VERSION=latest
SONARR_VERSION=latest
RADARR_VERSION=latest
LIDARR_VERSION=latest
PROWLARR_VERSION=latest
OVERSEERR_VERSION=latest
SABNZBD_VERSION=latest
BAZARR_VERSION=latest
NAVIDROME_VERSION=latest
NPM_VERSION=latest
NODE_EXPORTER_VERSION=latest
CADVISOR_VERSION=latest
PROMTAIL_VERSION=latest

# ---------------------------------------------------------------------------
# Plex — Media server
# ---------------------------------------------------------------------------
# Claim token for initial server setup (get from https://plex.tv/claim)
# Only needed on FIRST deploy — leave empty after initial setup
PLEX_CLAIM=

# ---------------------------------------------------------------------------
# Navidrome — Music streaming
# ---------------------------------------------------------------------------
# Last.fm scrobbling (optional — leave empty to disable)
NAVIDROME_ND_LASTFM_APIKEY=
NAVIDROME_ND_LASTFM_SECRET=
